# Copy to .env next to Collector.py and fill in. Every value below is the
# built-in default, so you only need the lines you actually want to change.

# --- MariaDB (schema from db/weather.sql) ---
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=weather
DB_PASSWORD=
DB_NAME=weather
# Read-only credentials for ai_agent.py's MetricStorage - it never writes.
DB_USER_READONLY=weather_read
DB_PASSWORD_READONLY=

# --- Hubitat Maker API ---
HUBITAT_IP=192.168.1.214
HUBITAT_APP_ID=7
HUBITAT_TOKEN=

# --- Weather station, via its MCP server (python McpMultiHttpServer.py) ---
WEATHER_MCP_URL=http://localhost:8000/weather/sse
# The physical weather station's own HTTP API, queried by the MCP server
# (McpWeather.py) itself.
WEATHER_STATION_URL=http://192.168.1.7:8080/api/status
# The station is not a Hubitat device, so it needs ids of its own. Keep
# WEATHER_SENSOR_ID clear of the Hubitat device id range.
WEATHER_SENSOR_ID=1000
WEATHER_SENSOR_NAME=WeatherStation
WEATHER_LOCATION_ID=100
WEATHER_LOCATION_NAME=Weather station
WEATHER_LOCATION_OUTSIDE=false

# --- Ollama ---
OLLAMA_URL=http://pi-host:11434
OLLAMA_MODEL_1=llama3.2
OLLAMA_MODEL_2=llama3.2
OLLAMA_MODEL_3=llama3.2

# --- Scheduling ---
INTERVAL_SECONDS=600

# Collect but write nothing - log the prepared SQL INSERTs instead.
# The --dry-run command-line flag does the same thing.
DRY_RUN=false

# --- Fallback location for Hubitat devices with no room assigned ---
DEFAULT_LOCATION_ID=0
DEFAULT_LOCATION_NAME=Unassigned

# --- Logging ---
# One of DEBUG, INFO, WARNING, ERROR, CRITICAL.
LOG_LEVEL=INFO
# Rotated every 24h from process start. Point this at a mounted volume in
# Docker so rotated logs survive container restarts. Set empty to disable
# file logging and keep console output only. Leave unset (comment out the
# line below) to let each app pick its own default filename under logs/ -
# collector.log, ai_agent.log, mcp_server.log - so all three can safely
# share one mounted logs/ directory without colliding.
#LOG_FILE=logs/app.log
# Rotated log files to keep before the oldest is deleted. 0 keeps all.
LOG_BACKUP_COUNT=7
