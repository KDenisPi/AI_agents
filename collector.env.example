# Copy to .env next to Collector.py and fill in. Every value below is the
# built-in default, so you only need the lines you actually want to change.

# --- MariaDB (schema from db/weather.sql) ---
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=weather
DB_PASSWORD=
DB_NAME=weather
# Read-only credentials for ai_agent.py's MetricStorage - it never writes.
DB_USER_READONLY=weather_read
DB_PASSWORD_READONLY=

# --- Hubitat Maker API ---
HUBITAT_IP=192.168.1.214
HUBITAT_APP_ID=7
HUBITAT_TOKEN=

# --- Weather station, via its MCP server (python McpMultiHttpServer.py) ---
WEATHER_MCP_URL=http://localhost:8000/weather/sse
# The physical weather station's own HTTP API, queried by the MCP server
# (McpWeather.py) itself.
WEATHER_STATION_URL=http://192.168.1.7:8080/api/status
# The station is not a Hubitat device, so it needs ids of its own. Keep
# WEATHER_SENSOR_ID clear of the Hubitat device id range.
WEATHER_SENSOR_ID=1000
WEATHER_SENSOR_NAME=WeatherStation
WEATHER_LOCATION_ID=100
WEATHER_LOCATION_NAME=Weather station
WEATHER_LOCATION_OUTSIDE=false

# --- Ollama ---
OLLAMA_URL=http://192.168.1.57:11434
# A bare name resolves to <name>:latest, so keep the tag when the server only
# has a tagged build - "llama3.1" is not "llama3.1:8b". Check what is actually
# pulled with: curl http://192.168.1.57:11434/api/tags
OLLAMA_MODEL_1=llama3.1:8b
OLLAMA_MODEL_2=qwen3.6
# Speech synthesis (text_to_voice.py). Must be an Orpheus-style model that
# emits SNAC audio tokens - a general chat model returns prose, not audio.
OLLAMA_MODEL_TEXT_TO_VOICE=sematre/orpheus:en-3b
# Trained voices: tara, leah, jess, leo, dan, mia, zac, zoe.
OLLAMA_VOICE=tara
VOICE_OUTPUT_DIR=voice_output
# Rough token budget (~4 chars/token) for the verbatim chat history sent on
# each call before older turns get folded into a summary, and how many of
# the most recent messages stay verbatim once that happens. Tune to the
# model's actual num_ctx.
OLLAMA_MAX_HISTORY_TOKENS=3000
OLLAMA_KEEP_RECENT_MESSAGES=10

# --- AI agent HTTP API (ai_agent_server.py) ---
AI_AGENT_HOST=0.0.0.0
AI_AGENT_PORT=8100
# Where the agent POSTs the answer once a GET request has been accepted and
# processed - see ai_agent_server.py's module docstring for the contract.
# ai_client/simple_client.py listens here by default.
AI_CLIENT_CALLBACK_URL=http://127.0.0.1:9100/api/response
AI_CLIENT_CALLBACK_TIMEOUT=10
# Base URL clients use to reach this server, used to build the audio_url of
# a "?voice" request. Left empty, that link is root-relative (/audio/...),
# which the client resolves against the address it already called. Set it
# only when the link must stand alone - AI_AGENT_HOST above is a bind
# address, so it cannot be used to build one.
#AI_AGENT_PUBLIC_URL=http://192.168.1.254:8100

# --- Scheduling ---
INTERVAL_SECONDS=600

# Collect but write nothing - log the prepared SQL INSERTs instead.
# The --dry-run command-line flag does the same thing.
DRY_RUN=false

# --- Fallback location for Hubitat devices with no room assigned ---
DEFAULT_LOCATION_ID=0
DEFAULT_LOCATION_NAME=Unassigned

# --- Logging ---
# One of DEBUG, INFO, WARNING, ERROR, CRITICAL.
LOG_LEVEL=INFO
# Rotated every 24h from process start. Point this at a mounted volume in
# Docker so rotated logs survive container restarts. Set empty to disable
# file logging and keep console output only. Leave unset (comment out the
# line below) to let each app pick its own default filename under logs/ -
# collector.log, ai_agent.log, mcp_server.log - so all three can safely
# share one mounted logs/ directory without colliding.
#LOG_FILE=logs/app.log
# Rotated log files to keep before the oldest is deleted. 0 keeps all.
LOG_BACKUP_COUNT=7
